# ═══════════════════════════════════════════════════════════
# 7venHotel Cloud — Configuration Environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════════════════════

# ── ENVIRONNEMENT ────────────────────────────────────────
NODE_ENV=production
APP_NAME="7venHotel Cloud"
APP_URL=https://votre-domaine.com
APP_PORT=3001
APP_VERSION=1.0.0

# ── BASE DE DONNÉES PostgreSQL ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ocs7venhotel
DB_USER=ocs7venhotel_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false

# ── CACHE Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ── AUTHENTIFICATION JWT ──────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_VERY_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ── IA ANTHROPIC (Ouwalou) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000

# ── FICHIERS & UPLOADS ────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
MAX_IMAGES_PER_ROOM=7
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ── EMAIL (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@votre-domaine.com
SMTP_PASS=CHANGE_ME_EMAIL_PASSWORD
EMAIL_FROM_NAME="7venHotel Cloud"
EMAIL_FROM_ADDRESS=noreply@votre-domaine.com

# ── DEVISE & LOCALISATION ─────────────────────────────────
DEFAULT_CURRENCY=XAF
DEFAULT_TIMEZONE=Africa/Douala
DEFAULT_LANGUAGE=fr
DEFAULT_LOCALE=fr-CM

# ── LOGS ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30

# ── SÉCURITÉ ──────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=15
CORS_ORIGINS=https://votre-domaine.com,http://localhost:3000
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ── SUPER ADMIN INITIAL ───────────────────────────────────
SUPER_ADMIN_EMAIL=admin@7venhotel.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SUPER_ADMIN_NAME="Super Administrateur"

# ── FRONTEND ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://votre-domaine.com/api
NEXT_PUBLIC_APP_NAME="7venHotel Cloud"
NEXT_PUBLIC_DEFAULT_CURRENCY=XAF
NEXT_PUBLIC_DEFAULT_TIMEZONE=Africa/Douala
NEXT_PUBLIC_STRIPE_KEY=pk_live_CHANGE_ME
